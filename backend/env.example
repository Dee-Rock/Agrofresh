# Supabase Configuration
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# PostgreSQL Session Store
DATABASE_URL=postgresql://postgres:your_db_password@db.your-project-ref.supabase.co:5432/postgres

# Optional MySQL Source (only if you still have old DB access)
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=agrofresh

# If MySQL is not reachable, set true to run bootstrap mode
ALLOW_NO_MYSQL=true

# Optional bootstrap admin seed for no-MySQL mode
SEED_ADMIN_NAME=Platform Admin
SEED_ADMIN_EMAIL=admin@agrofresh.com
SEED_ADMIN_PASSWORD=ChangeThisNow123!

# Session Configuration
SESSION_SECRET=your-secret-key-change-this

# Sendstack Configuration
SENDSTACK_APP_ID=your_sendstack_app_id
SENDSTACK_APP_SECRET=your_sendstack_app_secret
SENDSTACK_API_KEY=your_sendstack_api_key

# Server Configuration
PORT=4000
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000 